MONGODB_URL=mongodb://127.0.0.1:27017/electronic-educare
JWT_SECRET=replace-with-a-long-random-secret
ROOT_DOMAIN=electroniceducare.com
MAIN_DOMAIN=electroniceducare.com
TRUST_PROXY=loopback
# Development only: allow browser origins on private Wi-Fi address ranges.
# This setting is ignored when NODE_ENV=production.
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_LAN=true
# Development only: permit school credentials through localhost/LAN IP login.
# Production tenant accounts still require their resolved organization domain.
ALLOW_SHARED_DOMAIN_TENANT_LOGIN=true
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL_MS=600000
# Generate with: openssl rand -base64 32
PAYMENT_ENCRYPTION_KEY=replace-with-a-32-byte-base64-value
RAZORPAY_TIMEOUT_MS=10000
# Optional outside Render. Render provides RENDER_EXTERNAL_URL automatically.
# KEEP_ALIVE_URL=https://your-service.onrender.com/health
